# Copy to .env and customize. Used only by docker-compose locally.
# Production secrets live in the private ops/ tree, never here.

# ─── Host-side port mappings ────────────────────────────────────────────────
# Override only if default ports are taken by another project on your machine.
# The in-container ports never change; these only affect `localhost:<PORT>`.
# NGINX_HOST_PORT=80
# SEAWEEDFS_S3_HOST_PORT=8333
# SEAWEEDFS_MASTER_HOST_PORT=9333
# SEAWEEDFS_FILER_HOST_PORT=8888
# TUSD_HOST_PORT=1080

# ─── Shared Postgres (accounting-api's local stack) ─────────────────────────
# This project does NOT run its own Postgres. Instead it piggybacks on the
# accounting-api local dev stack, which exposes accounting-postgres on :5432.
# Run `./scripts/create-databases.sh` once to provision learn_api_* DBs +
# learn_api_user role on that instance.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Superuser credentials of the shared accounting-postgres container (defaults
# baked into accounting-api's compose — these are dev-only, not secrets).
POSTGRES_SUPERUSER=postgres
POSTGRES_SUPERUSER_PASSWORD=changeme
# Password assigned to learn_api_user by `create-databases.sh`.
# Real value for any non-local environment comes from a secrets store, not here.
LEARN_API_DB_PASSWORD=learn_dev

# ─── Shared Redis (accounting-api's local stack) ────────────────────────────
# Same story: this project shares accounting-redis on :6379 and isolates
# itself with the `learn:` key prefix. Password baked into accounting-api's
# compose — dev-only.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_password

# ─── Disk-alert script ──────────────────────────────────────────────────────
# Recipient for the SeaweedFS usage alert. Root is sensible on the VPS;
# set to a real address for anything longer-lived.
ALERT_EMAIL=root

# ─── SeaweedFS S3 credentials (learn-api identity) ───────────────────────────
# Must match the `learn-api-rw` identity in ./seaweedfs/s3.json.
S3_ACCESS_KEY=learn_access_key
S3_SECRET_KEY=learn_secret_key
# Endpoint the API uses when issuing pre-signed URLs / reading from S3.
S3_ENDPOINT=http://localhost:8333

# ─── tusd S3 credentials (scoped identity) ───────────────────────────────────
# Must match the `tusd-upload` identity in ./seaweedfs/s3.json.
# tusd uses these via AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY in docker-compose.
TUSD_ACCESS_KEY=tusd_access_key
TUSD_SECRET_KEY=tusd_secret_key

# ─── Nginx secure_link (HLS signed URLs) ─────────────────────────────────────
# The shared secret between nginx (local.conf) and the sign-hls-url.sh helper.
# The baked-in dev default in local.conf is this same value; keep them aligned.
# Any non-local environment should generate a fresh high-entropy secret and
# keep it out of the repo: `openssl rand -hex 32`.
SECURE_LINK_SECRET=local_dev_secret_do_not_use_in_prod
