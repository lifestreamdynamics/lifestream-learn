# ============================================================
# Lifestream Learn infra — PRODUCTION environment template
# ============================================================
# This file is a TEMPLATE. Safe to commit: every secret slot is
# `REPLACE_ME` and no environment-specific paths or hostnames
# are baked in.
#
# Real values live in the private, git-ignored
# `ops/env/infra.production.env` on the operator's local machine
# and are deployed to the VPS as `/etc/learn-infra/.env` (root-owned,
# chmod 600) by the deploy script. They feed
# `docker compose -f docker-compose.yml -f docker-compose.prod.yml`
# on the VPS when the seaweedfs + tusd services come up.
#
# To stamp out a fresh prod infra env, run:
#   cp infra/.env.production.example ops/env/infra.production.env
#   chmod 600 ops/env/infra.production.env
# then fill in every REPLACE_ME slot.
#
# Generators referenced below:
#   openssl rand -hex 32      # 256-bit hex (nginx secure_link format)
#   openssl rand -base64 24   # 192-bit shared secret (tusd hook)
# ============================================================

# ─── Host-side port mappings (bound to 127.0.0.1 via the prod overlay) ──────
# These ports are only reachable via the system-level nginx in prod; the
# compose overlay binds them to loopback so they never face the public
# internet. Only override if another loopback-bound service collides.
# SEAWEEDFS_S3_HOST_PORT=8333
# SEAWEEDFS_MASTER_HOST_PORT=9333
# SEAWEEDFS_FILER_HOST_PORT=8888
# TUSD_HOST_PORT=1080

# ─── SeaweedFS data directory on the host ───────────────────────────────────
# Points at the block-storage mount on the VPS. Attach a volume ≥ 100 GB at
# this path before the first real deploy (see deploy/README.md). Falls back
# to a compose-managed named volume if unset — fine for a smoke test, NOT
# fine for ongoing production use (you'll lose data on a compose down -v).
SEAWEEDFS_DATA_DIR=/mnt/seaweedfs-data

# ─── Shared Postgres on the VPS ─────────────────────────────────────────────
# Postgres is provisioned on the VPS itself (not in compose). We target the
# `learn_api_user` role and `learn_api_production` DB only — never reach into
# other projects' schemas.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Superuser credentials are needed once for `create-databases.sh` during
# bootstrap. After bootstrap, wipe these from the env file — only the
# operator's shell session during provisioning should ever hold them.
POSTGRES_SUPERUSER=REPLACE_ME_only_during_bootstrap
POSTGRES_SUPERUSER_PASSWORD=REPLACE_ME_only_during_bootstrap
# Password assigned to learn_api_user. MUST match the password embedded in
# DATABASE_URL in ops/env/api.production.env. openssl rand -base64 24
LEARN_API_DB_PASSWORD=REPLACE_ME_openssl_rand_base64_24

# ─── Shared Redis on the VPS ────────────────────────────────────────────────
# Redis runs on the VPS; all learn-api keys are prefixed `learn:` for
# isolation against accounting-api / galaxy-miner / future services.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=REPLACE_ME_shared_redis_password

# ─── Disk-alert script ──────────────────────────────────────────────────────
# Recipient for the SeaweedFS usage alert. Local root mail is a reasonable
# default on the VPS; swap for a real address once outbound mail is wired.
ALERT_EMAIL=root

# ─── SeaweedFS S3 credentials (learn-api identity) ──────────────────────────
# Must match the `learn-api-rw` identity in the compose-mounted s3.json.
S3_ACCESS_KEY=REPLACE_ME
S3_SECRET_KEY=REPLACE_ME
S3_ENDPOINT=http://127.0.0.1:8333

# ─── tusd S3 credentials (scoped, write-only against learn-uploads) ─────────
# Must match the `tusd-upload` identity in the compose-mounted s3.json.
TUSD_ACCESS_KEY=REPLACE_ME
TUSD_SECRET_KEY=REPLACE_ME

# ─── Nginx secure_link (HLS signed URLs) ────────────────────────────────────
# Shared HMAC secret between the system-level nginx and the API's hls-signer.
# MUST match HLS_SIGNING_SECRET in ops/env/api.production.env byte-for-byte.
# openssl rand -hex 32
SECURE_LINK_SECRET=REPLACE_ME_openssl_rand_hex_32

# ─── tusd → learn-api webhook auth ──────────────────────────────────────────
# MUST match TUSD_HOOK_SECRET in ops/env/api.production.env.
# openssl rand -base64 24
TUSD_HOOK_SECRET=REPLACE_ME_openssl_rand_base64_24

# ─── tusd upload size cap ───────────────────────────────────────────────────
# Matches the API's VIDEO_MAX_BYTES guard. Leave at the 2 GiB default unless
# the ingest pipeline has been proven against larger payloads.
# TUSD_MAX_SIZE_BYTES=2147483648
