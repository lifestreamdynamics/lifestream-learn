# ============================================================
# Lifestream Learn API — PRODUCTION environment template
# ============================================================
# This file is a TEMPLATE. It is safe to commit: every secret
# slot is `REPLACE_ME` and every hostname slot is a placeholder.
# No real production hostnames or domains are baked in — fill them
# in only in the operator's private `ops/env/api.production.env`.
#
# Real values for a given deployment live in the private,
# git-ignored `ops/env/api.production.env` on the operator's
# local machine, and are copied to the VPS at `/etc/learn-api/.env`
# (root-owned, chmod 600) by the deploy script.
#
# To stamp out a fresh prod env file, run:
#   cp api/.env.production.example ops/env/api.production.env
#   chmod 600 ops/env/api.production.env
# then fill in every REPLACE_ME slot.
#
# Generators referenced below:
#   openssl rand -base64 48   # 384-bit secret (JWT / IP hash salt / HLS signing)
#   openssl rand -base64 32   # 256-bit key (MFA encryption)
#   openssl rand -base64 24   # 192-bit shared secret (tusd hook)
#   openssl rand -hex 32      # 256-bit hex (matches nginx secure_link format)
# ============================================================

# ---------- Runtime ----------
NODE_ENV=production
# Reserved prod port (IMPLEMENTATION_PLAN.md §3 — never collide with :3100
# accounting-api or :3177 galaxy-miner on the shared VPS).
PORT=3101
LOG_LEVEL=info

# ---------- Database ----------
# `learn_api_user` is our only role; `learn_api_production` is our only DB.
# `connection_limit=20` keeps the Prisma pool from fighting other services on
# the shared Postgres 16 instance.
DATABASE_URL=postgresql://learn_api_user:REPLACE_ME@localhost:5432/learn_api_production?connection_limit=20

# ---------- Redis ----------
# Shared Redis on the VPS. `learn:` prefix isolates our keys from the other
# services on the same instance — never drop the prefix.
REDIS_URL=redis://:REPLACE_ME@localhost:6379
REDIS_KEY_PREFIX=learn:

# ---------- Auth ----------
# Generate each of these with: openssl rand -base64 48
# The three values MUST be different from each other.
JWT_ACCESS_SECRET=REPLACE_ME_openssl_rand_base64_48
JWT_REFRESH_SECRET=REPLACE_ME_openssl_rand_base64_48_different_from_access
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
# Salt used to hash remote IPs before persisting on Session rows.
# Minimum 32 chars. openssl rand -base64 48
IP_HASH_SALT=REPLACE_ME_openssl_rand_base64_48

# ---------- Object storage (SeaweedFS S3 — local to the VPS) ----------
# SeaweedFS runs on the same box via docker-compose.prod.yml, bound to
# 127.0.0.1:8333 only. System nginx is the sole public-facing edge.
S3_ENDPOINT=http://127.0.0.1:8333
S3_REGION=us-east-1
S3_ACCESS_KEY=REPLACE_ME
S3_SECRET_KEY=REPLACE_ME
S3_UPLOAD_BUCKET=learn-uploads
S3_VOD_BUCKET=learn-vod
S3_FORCE_PATH_STYLE=true

# ---------- Resumable upload (tusd) ----------
# System nginx proxies /uploads/* to the internal tusd daemon bound to
# 127.0.0.1:1080.
TUSD_PUBLIC_URL=https://REPLACE_ME_PUBLIC_API_HOST/uploads
# Shared secret tusd forwards on its pre-finish / post-finish webhooks.
# openssl rand -base64 24
TUSD_HOOK_SECRET=REPLACE_ME_openssl_rand_base64_24

# ---------- HLS signed URLs ----------
# Public base URL for HLS playlists and segments. System nginx validates
# the secure_link HMAC before proxying to SeaweedFS.
HLS_BASE_URL=https://REPLACE_ME_PUBLIC_API_HOST/hls
# MUST match the secret plugged into the nginx secure_link snippet on the
# VPS (/etc/learn-api/secure-link-secret). openssl rand -base64 48
HLS_SIGNING_SECRET=REPLACE_ME_openssl_rand_base64_48
HLS_SIGNING_TTL_SECONDS=7200

# ---------- CORS ----------
# Landing page (static) lives at the public landing host. The API's own
# origin is NOT listed here — same-origin requests don't need CORS.
# Add additional web origins only if a web client is introduced later.
CORS_ALLOWED_ORIGINS=https://REPLACE_ME_PUBLIC_LANDING_HOST

# ---------- Seed ----------
# Prod NEVER seeds a sample video. This is a hard guardrail — the seed
# script refuses to run the upload path when NODE_ENV=production AND
# SEED_SAMPLE_VIDEO=false. Do not flip this to true.
SEED_ADMIN_EMAIL=REPLACE_ME_admin_email
SEED_ADMIN_PASSWORD=REPLACE_ME_strong_admin_password
SEED_DESIGNER_EMAIL=REPLACE_ME_designer_email
SEED_LEARNER_EMAIL=REPLACE_ME_learner_email
SEED_DEV_USER_PASSWORD=REPLACE_ME_strong_seed_password
SEED_SAMPLE_VIDEO=false

# ---------- Transcode worker ----------
# Single-concurrency on the current 3.8 GB / 2-core VPS. Revisit when the
# box gets a RAM bump (see ops/vps-prereq-check-2026-04-18.md).
TRANSCODE_CONCURRENCY=1
# Working directory for FFmpeg job downloads + outputs. On the VPS this
# should sit on the same volume as the SeaweedFS data dir so rename ops
# stay cheap.
TRANSCODE_TMP_DIR=/var/tmp/learn-transcode
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe
# 90-second video cap for pre-beta on 3.8 GB / 2-core box. Raise this
# deliberately, with the runbook's RAM/volume follow-ups done first.
VIDEO_MAX_DURATION_MS=90000

# ---------- Observability (Slice G1) ----------
# /metrics is mounted on the API's :3101. The nginx site config IP-allowlists
# this path so the public edge denies it — internal scrape only.
METRICS_ENABLED=true

# Out-of-process crash reporter. Provide endpoint + API key from whichever
# reporter is in use for the deployment (e.g. Sentry-compatible).
CRASH_REPORTING_ENABLED=true
LEARN_CRASH_API_KEY=REPLACE_ME
LEARN_CRASH_ENDPOINT=REPLACE_ME

# ---------- HTTP server tuning (Slice G2) ----------
# Align with upstream nginx keepalive. headersTimeout MUST be greater than
# keepAliveTimeout or Node refuses the config at boot.
HTTP_KEEPALIVE_MS=65000
HTTP_HEADERS_TIMEOUT_MS=66000

# ---------- MFA (Slice P7a) ----------
# AES-256-GCM key for encrypting TOTP secrets at rest. 32 bytes base64.
# openssl rand -base64 32
MFA_ENCRYPTION_KEY=REPLACE_ME_openssl_rand_base64_32
MFA_TOTP_ISSUER="Lifestream Learn"

# ---------- MFA WebAuthn / Passkeys (Slice P7b) ----------
# Relying Party ID = domain-only, no scheme, no port.
WEBAUTHN_RP_ID=REPLACE_ME_PUBLIC_API_HOST
WEBAUTHN_RP_NAME="Lifestream Learn"
# Full origin strings the server accepts. Byte-for-byte match — no wildcards.
# The Android origin is `android:apk-key-hash:<BASE64URL(SHA-256(signing-cert))>`
# derived from the PROD signing keystore (not the debug keystore).
# Generate for the prod keystore with:
#   keytool -list -v -keystore <path-to-prod-keystore.jks> \
#     -alias <alias> -storepass <storepass> | grep SHA-256
# then convert the hex SHA-256 to raw bytes, base64url-encode without padding,
# and substitute for REPLACE_ME below.
WEBAUTHN_ORIGIN=https://REPLACE_ME_PUBLIC_API_HOST,android:apk-key-hash:REPLACE_ME_with_prod_signing_cert_hash

# ---------- Auth rate-limit ceilings (Slice G2) ----------
RATE_LIMIT_SIGNUP_MAX=10
RATE_LIMIT_SIGNUP_WINDOW_MS=600000
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_LOGIN_WINDOW_MS=300000
RATE_LIMIT_REFRESH_MAX=30
RATE_LIMIT_REFRESH_WINDOW_MS=300000
# tusd-hook limiter caps pre-finish deliveries per-IP so a leaked or
# brute-forced TUSD_HOOK_SECRET can't flood the transcode queue.
RATE_LIMIT_TUSD_HOOK_MAX=60
RATE_LIMIT_TUSD_HOOK_WINDOW_MS=60000
