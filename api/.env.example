# ---------- Runtime ----------
NODE_ENV=development
PORT=3011
LOG_LEVEL=debug

# ---------- Database ----------
DATABASE_URL=postgresql://learn_api_user:CHANGE_ME@localhost:5432/learn_api_development

# ---------- Redis ----------
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=learn:

# ---------- Auth ----------
# Generate with: openssl rand -base64 48
JWT_ACCESS_SECRET=CHANGE_ME_to_long_random_string
JWT_REFRESH_SECRET=CHANGE_ME_to_different_long_random_string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# ---------- Object storage (SeaweedFS S3) ----------
S3_ENDPOINT=http://localhost:8333
S3_REGION=us-east-1
S3_ACCESS_KEY=CHANGE_ME
S3_SECRET_KEY=CHANGE_ME
S3_UPLOAD_BUCKET=learn-uploads
S3_VOD_BUCKET=learn-vod
S3_FORCE_PATH_STYLE=true

# ---------- Resumable upload (tusd) ----------
TUSD_PUBLIC_URL=http://localhost:1080/files

# ---------- HLS signed URLs ----------
HLS_BASE_URL=http://localhost:8080/hls
# Nginx secure_link HMAC secret; must match Nginx config
HLS_SIGNING_SECRET=CHANGE_ME
HLS_SIGNING_TTL_SECONDS=7200

# ---------- CORS ----------
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ---------- Seed ----------
# Admin user created by `npm run prisma:seed`. Password is auto-generated and
# logged once if omitted (dev only). Set a stable value for repeatable setups.
SEED_ADMIN_EMAIL=admin@example.local
SEED_ADMIN_PASSWORD=

# ---------- Transcode worker ----------
# Must match the X-Tusd-Hook-Token header forwarded by tusd (see
# infra/docker-compose.yml). Minimum 16 chars.
TUSD_HOOK_SECRET=CHANGE_ME_at_least_16_chars
# How many concurrent FFmpeg jobs per worker process. Keep at 1 unless you
# know the host can parallelize without thrashing.
TRANSCODE_CONCURRENCY=1
# Working directory for job downloads + FFmpeg outputs. Defaults to
# $TMPDIR/learn-transcode if omitted.
TRANSCODE_TMP_DIR=
# System FFmpeg binaries. Override when running inside a container with
# non-default paths.
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe
# ADR 0006 duration cap; longer sources are rejected in-worker as FAILED.
VIDEO_MAX_DURATION_MS=180000
