# ---------- Runtime ----------
NODE_ENV=development
PORT=3011
LOG_LEVEL=debug

# ---------- Database ----------
# Append `?connection_limit=20` for local k6 load-test runs so Prisma's
# default per-process pool (num_physical_cpus * 2 + 1) isn't the
# bottleneck at 200 VUs. See api/load/README.md and Slice G2 notes.
DATABASE_URL=postgresql://learn_api_user:CHANGE_ME@localhost:5432/learn_api_development

# ---------- Redis ----------
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=learn:

# ---------- Auth ----------
# Generate with: openssl rand -base64 48
JWT_ACCESS_SECRET=CHANGE_ME_to_long_random_string
JWT_REFRESH_SECRET=CHANGE_ME_to_different_long_random_string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
# Salt used to hash remote IP addresses before persisting on Session rows.
# Minimum 32 chars. Generate with: openssl rand -base64 48
IP_HASH_SALT=CHANGE_ME_to_at_least_32_chars_random_value

# ---------- Object storage (SeaweedFS S3) ----------
S3_ENDPOINT=http://localhost:8333
S3_REGION=us-east-1
S3_ACCESS_KEY=CHANGE_ME
S3_SECRET_KEY=CHANGE_ME
S3_UPLOAD_BUCKET=learn-uploads
S3_VOD_BUCKET=learn-vod
S3_FORCE_PATH_STYLE=true

# ---------- Resumable upload (tusd) ----------
TUSD_PUBLIC_URL=http://localhost:1080/files

# ---------- HLS signed URLs ----------
HLS_BASE_URL=http://localhost:8080/hls
# Nginx secure_link HMAC secret; must match Nginx config.
# Minimum 32 bytes (256 bits). Generate with: openssl rand -base64 48
HLS_SIGNING_SECRET=CHANGE_ME_at_least_32_chars
HLS_SIGNING_TTL_SECONDS=7200

# ---------- CORS ----------
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ---------- Seed ----------
# Three canonical users created by `npm run prisma:seed`:
#   - admin (ADMIN role)
#   - designer (COURSE_DESIGNER role)
#   - learner (LEARNER role)
# Passwords are auto-generated and logged once if left blank (dev only).
# Set stable values for repeatable local setups — bootstrap-dev.sh fills these
# in with `Dev12345!Pass` so the same credentials work across teardown / rebuild.
SEED_ADMIN_EMAIL=admin@example.local
SEED_ADMIN_PASSWORD=
SEED_DESIGNER_EMAIL=designer@example.local
SEED_LEARNER_EMAIL=learner@example.local
SEED_DEV_USER_PASSWORD=
# When true (default), seed creates a "Dev Sample 101" course + uploads the
# fixture at ops/fixtures/sample-module.mp4 through the real transcode pipeline.
# Requires the transcode worker to be running. Set to false for a DB-only seed.
SEED_SAMPLE_VIDEO=true

# ---------- Transcode worker ----------
# Must match the X-Tusd-Hook-Token header forwarded by tusd (see
# infra/docker-compose.yml). Minimum 16 chars.
TUSD_HOOK_SECRET=CHANGE_ME_at_least_16_chars
# How many concurrent FFmpeg jobs per worker process. Keep at 1 unless you
# know the host can parallelize without thrashing.
TRANSCODE_CONCURRENCY=1
# Working directory for job downloads + FFmpeg outputs. Defaults to
# $TMPDIR/learn-transcode if omitted.
TRANSCODE_TMP_DIR=
# System FFmpeg binaries. Override when running inside a container with
# non-default paths.
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe
# ADR 0006 duration cap; longer sources are rejected in-worker as FAILED.
VIDEO_MAX_DURATION_MS=180000

# ---------- Observability (Slice G1) ----------
# Mount GET /metrics (prom-client text format) on the API's port :3011. Default
# off so fresh dev clones expose no new surface until an operator opts in.
# Before deploying, IP-allowlist this path at the reverse proxy.
METRICS_ENABLED=false

# Forward unhandled errors to an out-of-process crash reporter. When false,
# errors log via pino and that's it (the test suite runs with this off so it
# never opens a network socket). When true, LEARN_CRASH_API_KEY and
# LEARN_CRASH_ENDPOINT must be set.
CRASH_REPORTING_ENABLED=false
LEARN_CRASH_API_KEY=
LEARN_CRASH_ENDPOINT=

# ---------- HTTP server tuning (Slice G2) ----------
# Align with upstream nginx keepalive (defaults to 75s upstream + 65s
# origin). headersTimeout must be greater than keepAliveTimeout or Node
# rejects the config.
HTTP_KEEPALIVE_MS=65000
HTTP_HEADERS_TIMEOUT_MS=66000

# ---------- MFA (Slice P7a) ----------
# AES-256-GCM key for encrypting TOTP secrets at rest. 32 bytes
# base64-encoded. Generate with: openssl rand -base64 32
MFA_ENCRYPTION_KEY=changeme-generate-with-openssl-rand-base64-32
# Label shown inside authenticator apps (Authy, Google Authenticator, …)
# alongside the user's email. Free-form; defaults to "Lifestream Learn".
MFA_TOTP_ISSUER=Lifestream Learn

# ---------- MFA WebAuthn / Passkeys (Slice P7b) ----------
# The "Relying Party ID" is a domain-only identifier the authenticator
# binds credentials to. For local Android-emulator dev keep it "localhost";
# in prod this is the real origin's domain without scheme/port (e.g.
# "learn.example.com"). See RFC 8471 / WebAuthn Level 3 §5.1.
WEBAUTHN_RP_ID=localhost
# Human-readable label shown in the browser / system passkey UI.
WEBAUTHN_RP_NAME=Lifestream Learn
# Comma-separated list of FULL origin strings the server accepts from
# `clientDataJSON.origin`. Byte-for-byte match — no wildcards.
#
# Android: the Credential Manager reports an origin of
#   `android:apk-key-hash:<BASE64URL(SHA-256(apk-signing-cert))>`.
# Derive for the debug keystore with:
#   keytool -list -v -keystore ~/.android/debug.keystore \
#     -alias androiddebugkey -storepass android | grep SHA-256
# Take the SHA-256 hex, convert to raw bytes, then base64url-encode
# (no padding). Append that origin to this list as a second CSV entry.
WEBAUTHN_ORIGIN=http://localhost:3011

# ---------- Auth rate-limit ceilings (Slice G2) ----------
# Prod-safe defaults. For local k6 load tests from a single IP, bump
# RATE_LIMIT_LOGIN_MAX to at least VUS × 2 to cover setup() + mid-run
# re-login when JWT_ACCESS_TTL expires. See api/load/README.md.
RATE_LIMIT_SIGNUP_MAX=10
RATE_LIMIT_SIGNUP_WINDOW_MS=600000
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_LOGIN_WINDOW_MS=300000
RATE_LIMIT_REFRESH_MAX=30
RATE_LIMIT_REFRESH_WINDOW_MS=300000
# tusd-hook limiter caps pre-finish deliveries per-IP so a leaked or
# brute-forced TUSD_HOOK_SECRET can't flood the transcode queue.
RATE_LIMIT_TUSD_HOOK_MAX=60
RATE_LIMIT_TUSD_HOOK_WINDOW_MS=60000
