#!/usr/bin/env bash
# Pre-push secret scan for lifestream-learn.
# Aims to catch obvious secret leaks before they reach a remote.
# Upgrade path: install gitleaks (brew install gitleaks / apt install gitleaks)
# and this hook will prefer it.
set -euo pipefail

remote="$1"
url="$2"

# Only scan commits being pushed (not already on remote).
# Format per line: <local ref> <local sha> <remote ref> <remote sha>
found=0
while read -r local_ref local_sha remote_ref remote_sha; do
  if [ "$local_sha" = "0000000000000000000000000000000000000000" ]; then
    continue  # branch deletion
  fi
  if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
    # new branch; scan all commits reachable from local_sha not on main
    range="$(git rev-parse --verify main 2>/dev/null && echo "main..$local_sha" || echo "$local_sha")"
  else
    range="$remote_sha..$local_sha"
  fi

  if command -v gitleaks >/dev/null 2>&1; then
    if ! gitleaks detect --no-banner --redact --log-level=warn --source . --log-opts="$range" 2>&1; then
      found=1
    fi
  else
    # Fallback: regex scan of diff
    patterns=(
      # AWS
      'AKIA[0-9A-Z]{16}'
      'aws_secret_access_key\s*=\s*[A-Za-z0-9/+=]{40}'
      # Private keys
      '-----BEGIN (RSA|OPENSSH|DSA|EC|PGP) PRIVATE KEY'
      # Generic high-entropy patterns (loose, but scoped to assignment form)
      '(password|passwd|pwd|secret|api[_-]?key|access[_-]?key)["'\'' ]*[:=]["'\'' ]*[A-Za-z0-9/+=_-]{20,}'
      # GitHub tokens
      'gh[pousr]_[A-Za-z0-9]{36,}'
      # Stripe
      'sk_live_[A-Za-z0-9]{24,}'
      # Slack
      'xox[baprs]-[A-Za-z0-9-]{10,}'
    )
    diff="$(git diff "$range" -- . ':(exclude).env.example' ':(exclude)**/.env.example' 2>/dev/null || true)"
    # Lines that hit the regexes below but are clearly NOT real secrets.
    # Every entry is a documented dev-default that already ships
    # publicly: the local SECURE_LINK_SECRET stub baked into
    # `infra/nginx/local.conf`, the `learn_*`/`tusd_*` SeaweedFS
    # identities defined in `infra/seaweedfs/s3.json`, and obvious
    # placeholder markers (`CHANGE_ME`, `REPLACE_ME`). A reviewer should
    # still eyeball the diff; this list only exists to keep the hook
    # from blocking on values that are intentionally public.
    safe_marker='do_not_use_in_prod|CHANGE_ME|REPLACE_ME|placeholder|example\.local|example\.invalid|learn_dev|learn_access_key|learn_secret_key|tusd_access_key|tusd_secret_key|CorrectHorseBattery1|Dev12345!Pass'
    for p in "${patterns[@]}"; do
      # `-- $p` prevents grep from treating a pattern that starts with `-`
      # (e.g. the private-key `-----BEGIN...` regex) as a command-line flag.
      matches="$(printf '%s' "$diff" | grep -E -i -- "$p" | grep -E -v -- "$safe_marker" || true)"
      if [ -n "$matches" ]; then
        echo "pre-push: possible secret matching /$p/:" >&2
        printf '%s\n' "$matches" | head -5 >&2
        found=1
      fi
    done
  fi
done

if [ $found -ne 0 ]; then
  echo "" >&2
  echo "pre-push: BLOCKED. Review the flagged lines above." >&2
  echo "If the match is a false positive, rewrite the commit or add the pattern to a baseline." >&2
  echo "Install gitleaks for richer scanning: https://github.com/gitleaks/gitleaks" >&2
  exit 1
fi

echo "pre-push: secret scan clean." >&2

# -----------------------------------------------------------------------------
# Shellcheck pass on shell scripts in the push range.
# -----------------------------------------------------------------------------
# Opt-in: only runs if shellcheck is installed, mirroring the gitleaks pattern
# above. BATS already exercises the scripts behaviourally; shellcheck is a
# static-analysis belt-and-braces. Fails the push on any shellcheck error
# (warnings are non-blocking).
if command -v shellcheck >/dev/null 2>&1; then
  shell_found=0
  # Re-walk the same ref range(s) the secret scan built above.
  # We accept a slight redundancy reading stdin twice-over by scanning
  # HEAD's diff instead, which matches what the operator is pushing.
  changed_shell_files="$(git diff --name-only --diff-filter=ACMR \
    "$(git merge-base HEAD @{upstream} 2>/dev/null || git rev-parse HEAD~1 2>/dev/null || echo HEAD)" \
    HEAD 2>/dev/null | grep -E '\.(sh|bash)$' || true)"
  if [ -n "$changed_shell_files" ]; then
    while IFS= read -r f; do
      [ -f "$f" ] || continue
      # -S error: warnings are informational only. BATS is the
      # behavioural guarantor; shellcheck here is a static-analysis
      # belt-and-braces that should never block on style-level hints.
      if ! shellcheck -S error -x "$f" >&2; then
        shell_found=1
      fi
    done <<< "$changed_shell_files"
    if [ "$shell_found" -ne 0 ]; then
      echo "pre-push: BLOCKED on shellcheck errors above." >&2
      exit 1
    fi
    echo "pre-push: shellcheck clean on changed .sh/.bash files." >&2
  fi
fi

exit 0
